{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "settings:changed",
  "description": "Broadcast when settings are updated via the API. Payload is the full current settings object.",
  "type": "object",
  "properties": {
    "photo_duration": { "type": "integer", "minimum": 1 },
    "shuffle": { "type": "boolean" },
    "transition_type": { "type": "string" },
    "transition_mode": { "type": "string" },
    "transition_duration_ms": { "type": "integer", "minimum": 0 },
    "kenburns_intensity": { "type": "string" },
    "photo_order": { "type": "string" },
    "qr_display_seconds": { "type": "integer", "minimum": 0 },
    "hdmi_schedule_enabled": { "type": "boolean" },
    "hdmi_off_time": { "type": "string", "pattern": "^[0-9]{1,2}:[0-9]{2}$" },
    "hdmi_on_time": { "type": "string", "pattern": "^[0-9]{1,2}:[0-9]{2}$" },
    "schedule_days": { "type": "string" },
    "max_upload_mb": { "type": "integer", "minimum": 1 },
    "auto_resize_max": { "type": "integer", "minimum": 0 },
    "auto_update_enabled": { "type": "boolean" },
    "pin_length": { "type": "integer", "enum": [4, 6] },
    "max_video_duration": { "type": "integer", "minimum": 0 },
    "web_port": { "type": "integer", "minimum": 1, "maximum": 65535 }
  },
  "required": [
    "photo_duration",
    "shuffle",
    "transition_type",
    "transition_mode",
    "transition_duration_ms",
    "kenburns_intensity",
    "photo_order",
    "qr_display_seconds",
    "hdmi_schedule_enabled",
    "hdmi_off_time",
    "hdmi_on_time",
    "schedule_days",
    "max_upload_mb",
    "auto_resize_max",
    "auto_update_enabled",
    "pin_length",
    "max_video_duration",
    "web_port"
  ],
  "additionalProperties": false
}
