# Pi Photo Display Configuration
# Copy to .env and modify as needed

# === Slideshow ===
MEDIA_DIR=/home/pi/media
PHOTO_DURATION=10
SHUFFLE=yes
LOOP=yes

# === Web Server ===
WEB_PORT=8080
MAX_UPLOAD_MB=200
# Optional PIN to protect upload/delete/settings/restart/reboot/shutdown actions.
# When set, the browser will prompt for credentials on destructive operations
# (use any username, the password must match this value).
# Leave empty for open access (suitable for trusted local networks).
WEB_PASSWORD=

# === Image Processing ===
# Max dimension (width or height) for auto-resizing uploaded images.
# Images larger than this are downscaled preserving aspect ratio.
# Set to 0 to disable auto-resize. Requires Pillow.
AUTO_RESIZE_MAX=1920
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
FLASK_SECRET_KEY=

# === File Extensions ===
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.gif,.webp,.tiff
VIDEO_EXTENSIONS=.mp4,.mkv,.avi,.mov,.webm,.m4v,.mpg,.mpeg

# === HDMI Schedule ===
HDMI_SCHEDULE_ENABLED=no
HDMI_OFF_TIME=22:00
HDMI_ON_TIME=08:00

# === System ===
AUTO_REFRESH=yes
REFRESH_INTERVAL=30
